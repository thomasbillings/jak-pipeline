# Mergify MCP server environment variables
#
# The REAL values for these variables belong in:
#   <downstream-project>/.claude/mcp/mergify/.env
#
# NEVER place real credentials in this repo's .env or mcp/mergify/.env —
# the server's env-leak-guard will refuse to start and exit non-zero if it
# detects credential keys in either of those in-repo locations.
#
# Copy this file to <downstream-project>/.claude/mcp/mergify/.env and fill
# in the real values.

# Mergify API key (obtain from https://dashboard.mergify.com -> API Keys)
# Format: mrg_live_<token> for production, mrg_test_<token> for staging
MERGIFY_API_KEY=

# Mergify organisation name (the GitHub org/user that owns your repos)
MERGIFY_ORG=

# GitHub personal access token (repo + read:org scopes required)
# Format: ghp_<token> (classic) or github_pat_<token> (fine-grained)
GITHUB_TOKEN=

# Role injected at agent dispatch — controls which tools this MCP instance exposes.
# Allowed values: scrum-master | pr-reviewer | dev-agent | planner
# See references/architecture.md §6 for the full role-gate matrix.
MERGIFY_MCP_ROLE=
