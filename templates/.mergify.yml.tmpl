# .mergify.yml — jak-pipeline named merge queues
#
# Generated from: jak-pipeline templates/.mergify.yml.tmpl
# Architecture reference: references/architecture.md §5
#
# Day 0 state: all queues start disabled: true.
# Activate one queue at a time per phase-rollout-commits.md.
#
# Global settings (apply to all queues):
#   merge_method: squash         — single commit per PR, clean history
#   update_method: rebase        — defeats force-push-during-queue races
#   batch_size: 1                — one PR per merge action
#   speculative_checks: 1        — test the queued state, not just head
#   allow_inplace_checks: true   — let same-SHA checks count without re-run

queue_rules:
  # Priority 4 (highest) — bug fixes; full CI gate
  - name: bug
    disabled: true
    priority: 4
    merge_method: squash
    update_method: rebase
    batch_size: 1
    speculative_checks: 1
    allow_inplace_checks: true
    queue_conditions:
      - "head~=^fix/"
      - "label=queue:bug"
      - "check-success-or-neutral=lint"
      - "check-success-or-neutral=typecheck"
      - "check-success-or-neutral=test"
      - "check-success-or-neutral=build"
    merge_conditions:
      - "check-success-or-neutral=lint"
      - "check-success-or-neutral=typecheck"
      - "check-success-or-neutral=test"
      - "check-success-or-neutral=build"

  # Priority 3 — plan PRs; lint + check-plan.sh only
  - name: plan
    disabled: true
    priority: 3
    merge_method: squash
    update_method: rebase
    batch_size: 1
    speculative_checks: 1
    allow_inplace_checks: true
    queue_conditions:
      - "head~=^plan/"
      - "label=queue:plan"
      - "check-success-or-neutral=lint"
      - "check-success-or-neutral=check-plan"
    merge_conditions:
      - "check-success-or-neutral=lint"
      - "check-success-or-neutral=check-plan"

  # Priority 2 — feature PRs; full CI gate
  - name: feature
    disabled: true
    priority: 2
    merge_method: squash
    update_method: rebase
    batch_size: 1
    speculative_checks: 1
    allow_inplace_checks: true
    queue_conditions:
      - "head~=^feat/"
      - "label=queue:feature"
      - "check-success-or-neutral=lint"
      - "check-success-or-neutral=typecheck"
      - "check-success-or-neutral=test"
      - "check-success-or-neutral=build"
    merge_conditions:
      - "check-success-or-neutral=lint"
      - "check-success-or-neutral=typecheck"
      - "check-success-or-neutral=test"
      - "check-success-or-neutral=build"

  # Priority 1 — infra/chore PRs; lint + unit only (no e2e)
  - name: infra
    disabled: true
    priority: 1
    merge_method: squash
    update_method: rebase
    batch_size: 1
    speculative_checks: 1
    allow_inplace_checks: true
    queue_conditions:
      - "head~=^chore/"
      - "label=queue:infra"
      - "check-success-or-neutral=lint"
      - "check-success-or-neutral=test"
    merge_conditions:
      - "check-success-or-neutral=lint"
      - "check-success-or-neutral=test"

  # Priority 0 (lowest) — design/CSS PRs; lint + unit fast lane (no UAT, no plan)
  - name: design
    disabled: true
    priority: 0
    merge_method: squash
    update_method: rebase
    batch_size: 1
    speculative_checks: 1
    allow_inplace_checks: true
    queue_conditions:
      - "head~=^design/"
      - "label=queue:design"
      - "check-success-or-neutral=lint"
      - "check-success-or-neutral=test"
    merge_conditions:
      - "check-success-or-neutral=lint"
      - "check-success-or-neutral=test"

pull_request_rules: []
