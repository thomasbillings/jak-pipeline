# .mergify.yml — jak-pipeline named merge queues
#
# Generated from: jak-pipeline templates/.mergify.yml.tmpl
# Architecture reference: references/architecture.md §5
#
# Day-0 state: `queue_rules: []` — no queue is active until the first phase
# rollout. Mergify v1 schema does NOT accept a `disabled: true` flag on a
# queue_rule, so the legacy disable mechanism is replaced with commented-out
# blocks below. Phase rollout = uncomment a block and move it into
# `queue_rules:` above; rollback = `git revert` the enable commit. One queue
# per commit. See `templates/phase-rollout-commits.md` for the exact diffs.
#
# Common settings used in every queue (apply when enabling):
#   merge_method: squash    — single commit per PR, clean history
#   update_method: rebase   — defeats force-push-during-queue races
#   batch_size: 1           — one PR per merge action
#
# Fields intentionally NOT present in this template (not valid in Mergify v1):
#   - `disabled`              — remove queue from config to disable
#   - `priority`              — would live in a top-level `priority_rules`
#                               section; not needed while one queue is active
#   - `speculative_checks`    — superseded by `batch_size`
#   - `allow_inplace_checks`  — deprecated; auto-computed by Mergify

queue_rules: []
pull_request_rules: []

# ──────────────────────────────────────────────────────────────────────
# Commented-out queue blocks below — enable one at a time per
# `templates/phase-rollout-commits.md`. To enable a queue:
#   1. Uncomment its block below.
#   2. Move the uncommented block into the `queue_rules:` list above
#      (replace `queue_rules: []` with `queue_rules:` and indent the
#      block as a YAML list item).
#   3. Commit. One queue per commit.
#
# Validation: `curl -H "Authorization: bearer $MERGIFY_API_KEY" \
#   https://api.mergify.com/v1/repos/<org>/<repo>/queues` should return 2xx
# after Mergify ingests the new config.
# ──────────────────────────────────────────────────────────────────────

