# DO NOT COMMIT real values. Copy this file to <downstream-project>/.claude/jira/.env
# and fill in your actual credentials there. The .env file is gitignored by install.sh.

# Base URL of your Jira instance (no trailing slash)
# Example: https://yourorg.atlassian.net
JIRA_BASE_URL=

# Email address associated with your Jira API token
# Example: you@yourorg.com
JIRA_EMAIL=

# Jira API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Jira project key used for board provisioning and JQL filters
# Example: SCRUM
JIRA_PROJECT=
