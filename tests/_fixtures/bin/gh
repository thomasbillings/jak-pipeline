#!/usr/bin/env bash
# PATH-shim for gh used in tests. Emits canned JSON based on GH_STUB_MODE / GH_CHECKS_MODE.
#
# GH_STUB_MODE (reviews endpoint):
#   reviews-approved-no-blockers   — approved review, BLOCKERS: 0
#   reviews-approved-has-blockers  — commented review, BLOCKERS: 1
#   reviews-empty                  — empty array
#
# GH_CHECKS_MODE (check-runs endpoint):
#   green   — all checks success (default)
#   failing — one check is failure

ARGS="$*"

if echo "$ARGS" | grep -q 'check-runs\|check_runs\|commits/'; then
  case "${GH_CHECKS_MODE:-green}" in
    failing)
      cat <<'JSON'
{"check_runs":[{"name":"lint","conclusion":"success"},{"name":"test","conclusion":"failure"}]}
JSON
      ;;
    *)
      cat <<'JSON'
{"check_runs":[{"name":"lint","conclusion":"success"},{"name":"test","conclusion":"success"}]}
JSON
      ;;
  esac
elif echo "$ARGS" | grep -q 'reviews'; then
  case "${GH_STUB_MODE:-reviews-approved-no-blockers}" in
    reviews-approved-no-blockers)
      cat <<'JSON'
[{"id":1,"commit_id":"abc123","user":{"login":"github-actions[bot]"},"state":"APPROVED","body":"## Review\n\nBLOCKERS: 0\n\ntests-state: green"}]
JSON
      ;;
    reviews-approved-has-blockers)
      cat <<'JSON'
[{"id":1,"commit_id":"abc123","user":{"login":"github-actions[bot]"},"state":"COMMENTED","body":"## Review\n\nBLOCKERS: 1\n\ntests-state: red"}]
JSON
      ;;
    reviews-empty)
      echo '[]'
      ;;
    *)
      echo '[]'
      ;;
  esac
else
  echo '[]'
fi
